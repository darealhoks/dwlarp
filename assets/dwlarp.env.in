# Generated by dwlarp installer from config.h. Do not edit by hand;
# edit config.h and re-run ./install.sh -r.
#
# Sourced by dwl-autostart so the cursor theme/size are exported into
# dbus + systemd user env, where wayland clients (foot, librewolf, …)
# pick them up.
export XCURSOR_THEME='@WS_CURSOR_THEME@'
export XCURSOR_SIZE=@WS_CURSOR_SIZE@
