#!/bin/sh
# dwl-autolayout — arrange outputs and repaint the wallpaper.
#
# Classifies outputs into "internal" (eDP-*, LVDS-*) and "external" (anything
# else). Picks the largest external by area, places it relative to the
# internal per the policy in:
#
#     ${XDG_CONFIG_HOME:-~/.config}/dwl/layout
#
# Format: <direction> [DX@DY]
#   direction: above | below | left | right
#   DX@DY:     optional pixel offset for the external monitor relative to its
#              auto-computed position. Negative values allowed.
#
# Examples:   above            (default centered)
#             left  10@-100    (left, 10px right and 100px up of centered)
#             right 0@200      (right, 200px lower)
#
# Idempotent. Single-output systems are left alone (dwl's default placement is
# fine when there's nothing to position relative to).

set -eu

CONF="${XDG_CONFIG_HOME:-$HOME/.config}/dwl/layout"
RAW=${DWL_LAYOUT:-}
[ -z "$RAW" ] && [ -r "$CONF" ] && RAW=$(awk 'NF{print; exit}' "$CONF")
[ -z "$RAW" ] && RAW=above

# Split: first word = policy, second word (optional) = DX@DY offset.
POLICY=${RAW%% *}
OFFSET=
case "$RAW" in *' '*) OFFSET=${RAW#* } ;; esac
DX=0; DY=0
if [ -n "$OFFSET" ]; then
    case "$OFFSET" in
        *@*) DX=${OFFSET%@*}; DY=${OFFSET#*@} ;;
        *)   echo "dwl-autolayout: bad offset '$OFFSET' (want DX@DY)" >&2; exit 2 ;;
    esac
    case "$DX$DY" in
        *[!0-9-]*) echo "dwl-autolayout: offset must be integers" >&2; exit 2 ;;
    esac
fi

# Pull all enabled outputs into shell vars: classify and pick the largest
# external. awk does the parsing & decision in one shot, emits sh assignments.
# Wallpaper repaint isn't our job — wisp recreates per-output widgets on
# wl_output add/remove and paints each one itself.
eval "$(timeout 3 wlr-randr 2>/dev/null | awk '
    function flush() {
        if (!en || !w || !h) return
        if (n ~ /^(eDP|LVDS)/) { iname=n; iw=w; ih=h }
        else if (w*h > ew*eh)  { ename=n; ew=w; eh=h }
    }
    /^[^ \t]/      { flush(); n=$1; en=0; w=0; h=0 }
    /Enabled: yes/ { en=1 }
    /current\)/    { split($1, m, "x"); w=m[1]+0; h=m[2]+0 }
    END {
        flush()
        printf "INAME=%s\nIW=%d\nIH=%d\nENAME=%s\nEW=%d\nEH=%d\n",
            iname, iw, ih, ename, ew, eh
    }
')"

# Single output (or no external). Pin whichever output we have to (0,0).
if [ -z "${ENAME:-}" ] || [ -z "${INAME:-}" ]; then
    only=${INAME:-${ENAME:-}}
    [ -n "$only" ] && timeout 3 wlr-randr --output "$only" --pos 0,0 || true
    exit 0
fi

# Compute positions. Whichever axis isn't the stack axis gets centered so the
# smaller monitor is centered against the larger one.
case "$POLICY" in
    above)
        if [ "$EW" -ge "$IW" ]; then ex=0; ix=$(( (EW - IW) / 2 ));
        else                          ix=0; ex=$(( (IW - EW) / 2 )); fi
        ey=0; iy=$EH ;;
    below)
        if [ "$EW" -ge "$IW" ]; then ex=0; ix=$(( (EW - IW) / 2 ));
        else                          ix=0; ex=$(( (IW - EW) / 2 )); fi
        iy=0; ey=$IH ;;
    left)
        if [ "$EH" -ge "$IH" ]; then ey=0; iy=$(( (EH - IH) / 2 ));
        else                          iy=0; ey=$(( (IH - EH) / 2 )); fi
        ex=0; ix=$EW ;;
    right)
        if [ "$EH" -ge "$IH" ]; then ey=0; iy=$(( (EH - IH) / 2 ));
        else                          iy=0; ey=$(( (IH - EH) / 2 )); fi
        ix=0; ex=$IW ;;
    *)
        echo "dwl-autolayout: unknown policy '$POLICY' (want: above|below|left|right)" >&2
        exit 2 ;;
esac

# Apply user offset to the external. Then shift everything so min coord is 0
# (negative origins make dwl-wallpaper's bbox math nonsensical).
ex=$(( ex + DX )); ey=$(( ey + DY ))

if [ "$ex" -lt "$ix" ]; then sx=$(( -ex )); else sx=$(( -ix )); fi
[ "$sx" -lt 0 ] && sx=0
if [ "$ey" -lt "$iy" ]; then sy=$(( -ey )); else sy=$(( -iy )); fi
[ "$sy" -lt 0 ] && sy=0
ex=$(( ex + sx )); ix=$(( ix + sx ))
ey=$(( ey + sy )); iy=$(( iy + sy ))

timeout 3 wlr-randr --output "$ENAME" --pos "${ex},${ey}" \
                    --output "$INAME" --pos "${ix},${iy}"
